    {
      "id": "win-cmd",
      "icon": "💻",
      "title": "Comandos Forense Windows",
      "badge": "PowerShell",
      "desc": "Comandos para ejecutar en caliente durante una investigación.",
      "content": [
        {
          "type": "code",
          "lang": "powershell",
          "lines": [
            "# Procesos con conexiones de red activas",
            "Get-NetTCPConnection | Where-Object State -eq Established",
            "# Scheduled tasks no-Microsoft",
            "Get-ScheduledTask | Where-Object TaskPath -notlike \"\\Microsoft\\*\"",
            "# Servicios con paths raros",
            "Get-CimInstance Win32_Service | Where-Object PathName -match \"(temp|users|appdata)\"",
            "# Run keys - persistencia",
            "Get-ItemProperty -Path \"HKLM:\\Software\\Microsoft\\Windows\\CurrentVersion\\Run\"",
            "# Logins remotos RDP",
            "Get-WinEvent -FilterHashtable @{LogName=\"Security\";ID=4624;LogonType=10}"
          ]
        }
      ]
    },
