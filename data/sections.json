    {
      "id": "forensics",
      "icon": "🔬",
      "title": "Forensia de Memoria RAM",
      "badge": "Volatility 3",
      "content": [
        {
          "type": "code",
          "lang": "shell",
          "lines": [
            "# Listar procesos (psscan detecta ocultos)",
            "volatility -f memory.dmp windows.psscan",
            "# Conexiones de red desde memoria",
            "volatility -f memory.dmp windows.netscan",
            "# Línea de comandos de cada proceso",
            "volatility -f memory.dmp windows.cmdline",
            "# Código inyectado (malfind)",
            "volatility -f memory.dmp windows.malfind",
            "# Handles a procesos (process hollowing)",
            "volatility -f memory.dmp windows.handles --pid 1234 --object-type Process",
            "# Scan de archivos en memoria",
            "volatility -f memory.dmp windows.filescan | grep -E \"(\\.exe|\\.dll)\""
          ]
        }
      ]
    },
    {
      "id": "malware",
      "icon": "🦠",
      "title": "Análisis de Malware",
      "badge": "Triage rápido",
      "content": [
        {
          "type": "code",
          "lang": "shell",
          "lines": [
            "# 1. Hashes (para VirusTotal)",
            "sha256sum muestra.exe",
            "# 2. Tipo de archivo real",
            "file muestra.exe",
            "# 3. Strings: buscar URLs, IPs",
            "strings muestra.exe | grep -ioE 'https?://[^\"\\'<> ]+'",
            "strings muestra.exe | grep -oE '\\\\b[0-9]{1,3}\\\\.[0-9]{1,3}\\\\.[0-9]{1,3}\\\\.[0-9]{1,3}\\\\b' | sort -u",
            "# 4. Secciones PE (packed?)",
            "objdump -h muestra.exe | grep -E \"\\\\.text|\\\\.data|\\\\.rdata\"",
            "# 5. Imports sospechosos",
            "pedump --imports muestra.exe | grep -E \"(VirtualAlloc|CreateRemoteThread|URLDownload)\"",
            "# 6. Timestamp de compilación",
            "exiftool muestra.exe | grep -i \"time|date\""
          ]
        }
      ]
    },
