      "id": "cheat",
      "icon": "📄",
      "title": "Cheat Sheet",
      "badge": "Comandos rápidos",
      "content": [
        {
          "type": "sub",
          "title": "Windows"
        },
        {
          "type": "code",
          "lang": "ps",
          "lines": [
            "netstat -ano | findstr ESTABLISHED",
            "Get-Process -Id 4321 | Select-Object *",
            "Get-CimInstance Win32_Service | Select Name, PathName, StartName",
            "Search-ADAccount -LockedOut | Select Name, SamAccountName"
          ]
        },
        {
          "type": "sub",
          "title": "Linux"
        },
        {
          "type": "code",
          "lang": "bash",
          "lines": [
            "find / -perm -4000 -type f 2>/dev/null   # SUID",
            "ss -tunap | grep ESTAB",
            "dpkg --verify",
            "last -10",
            "find /tmp /dev/shm -type f -mtime -1 2>/dev/null"
          ]
        },
        {
          "type": "sub",
          "title": "Red"
        },
        {
          "type": "code",
          "lang": "shell",
          "lines": [
            "tshark -r cap.pcap -T fields -e ip.src -e ip.dst | sort -u",
            "tshark -r cap.pcap -Y \"dns.flags.response == 0\" -T fields -e dns.qry.name | sort | uniq -c | sort -rn",
            "tcpdump -i eth0 -n port 53"
          ]
        },
        {
          "type": "sub",
          "title": "Conversiones"
        },
        {
          "type": "grid",
          "items": [
            {
              "i": "🧮",
              "t": "Bytes a GB",
              "d": "bytes / 1073741824"
            },
            {
              "i": "⏰",
              "t": "Epoch a fecha",
              "d": "date -d @1700000000"
            },
            {
              "i": "🔢",
              "t": "Hex a Decimal",
              "d": "printf \"%d\" 0x7F"
            },
            {
              "i": "🔄",
              "t": "Base64 Decode",
              "d": "echo \"dGVzdA==\" | base64 -d"
            },
            {
              "i": "🔐",
              "t": "Hash rápido",
              "d": "sha256sum archivo"
            },
            {
              "i": "🌐",
              "t": "URL Decode",
              "d": "python3 -c 'import urllib.parse; print(urllib.parse.unquote(\"%2F\"))'"
            }
          ]
        }
      ]
