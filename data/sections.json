    {
      "id": "queries",
      "icon": "⚡",
      "title": "Queries Útiles",
      "badge": "KQL / SPL / ESQL",
      "desc": "Queries prácticos para los SIEM más usados.",
      "content": [
        {
          "type": "tabs",
          "tabs": [
            {
              "label": "KQL (Sentinel)",
              "lang": "kql",
              "lines": [
                "# Office spawn -> proceso hijo (phishing)",
                "let Office = dynamic([\"winword.exe\",\"excel.exe\",\"outlook.exe\"]);",
                "let LOL = dynamic([\"powershell.exe\",\"cmd.exe\",\"rundll32.exe\",\"mshta.exe\"]);",
                "DeviceProcessEvents",
                "| where InitiatingProcessFileName has_any Office and FileName has_any LOL",
                "| project Timestamp, DeviceName, FileName, ProcessCommandLine, InitiatingProcessFileName",
                "",
                "# Lateral movement via RDP",
                "DeviceNetworkEvents",
                "| where RemotePort == 3389 and ActionType == \"ConnectionSuccess\"",
                "| summarize Count = count() by DeviceName, RemoteIP, LocalIP",
                "| where Count > 3"
              ]
            },
            {
              "label": "SPL (Splunk)",
              "lang": "spl",
              "lines": [
                "# Procesos hijos de Office",
                "index=windows EventCode=4688 (ParentProcess=\"winword.exe\" OR ParentProcess=\"excel.exe\" OR ParentProcess=\"outlook.exe\")",
                "| table _time, host, Account_Name, ProcessName, ParentProcess, CommandLine",
                "# Password spraying",
                "index=windows EventCode=4625",
                "| bucket _time span=5m",
                "| stats count by _time, Account_Name, Source_Network_Address",
                "| where count > 10",
                "# DNS queries DGA",
                "index=dns",
                "| eval entropy=len(query)-len(replace(query, \"[a-z]\", \"\"))",
                "| where len(query) > 20 AND entropy > 10"
              ]
            },
            {
              "label": "ESQL (Elastic)",
              "lang": "esql",
              "lines": [
                "// Procesos desde directorios temporales",
                "FROM logs-endpoint.events.process-*",
                "| WHERE STARTS_WITH(process.executable, \"C:\\\\Users\\\\\")",
                "    AND process.executable LIKE \"*\\\\AppData\\\\Local\\\\Temp\\\\*\"",
                "| STAT count = COUNT() BY host.hostname, process.name",
                "",
                "// Conexiones salientes a puertos no estándar",
                "FROM logs-endpoint.events.network-*",
                "| WHERE destination.port NOT IN (80, 443, 22, 53, 3389)",
                "| STAT count = COUNT() BY host.hostname, destination.address, destination.port"
              ]
            }
          ]
        }
      ]
    },
