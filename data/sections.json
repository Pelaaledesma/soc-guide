    {
      "id": "linux-cmd",
      "icon": "🐧",
      "title": "Comandos Forense Linux",
      "badge": "Bash",
      "desc": "Para investigación en caliente de endpoints Linux.",
      "content": [
        {
          "type": "code",
          "lang": "bash",
          "lines": [
            "# Procesos ocultos",
            "ps auxf",
            "ls -la /proc/*/exe 2>/dev/null | grep -E \"(deleted|tmp|dev/shm)\"",
            "# Módulos de kernel (rootkits)",
            "lsmod | sort",
            "# Archivos modificados últimas 24h",
            "find / -xdev -mtime -1 -type f -not -path \"/proc/*\" -not -path \"/sys/*\" 2>/dev/null",
            "# Persistencia via cron",
            "ls -la /etc/cron* /var/spool/cron/crontabs/",
            "# Conexiones de red activas",
            "ss -tunap",
            "# Archivos SUID (privilege escalation)",
            "find / -perm -4000 -type f 2>/dev/null",
            "# Comandos sospechosos en history",
            "cat ~/.bash_history 2>/dev/null | grep -E \"(wget|curl -o|nc |bash -i|python -c)\"",
            "# Archivos en /dev/shm",
            "ls -la /dev/shm/",
            "# Últimos logins",
            "last -10"
          ]
        }
      ]
    },
